{
  "entities": {
    "Report": {
      "title": "Report",
      "description": "A hyperlocal civic incident report",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the report" },
        "reporterId": { "type": "string", "description": "UID of the user who filed the report" },
        "reporterName": { "type": "string", "description": "Display name of the reporter" },
        "title": { "type": "string", "description": "Short title of the incident" },
        "description": { "type": "string", "description": "Detailed description of the problem" },
        "category": { "type": "string", "enum": ["Pothole", "Water Leakage", "Broken Streetlight", "Waste Management", "Infrastructure"], "description": "Category of the issue" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"], "description": "Calculated or manual severity level" },
        "imageUrl": { "type": "string", "description": "URL of the uploaded/mock photo" },
        "lat": { "type": "number", "description": "Latitude on the hyperlocal grid" },
        "lng": { "type": "number", "description": "Longitude on the hyperlocal grid" },
        "formattedAddress": { "type": "string", "description": "Civic street address" },
        "status": { "type": "string", "enum": ["reported", "validated", "in_progress", "resolved"], "description": "Progress state of the repair sweep" },
        "upvoteCount": { "type": "integer", "description": "Total upvotes received" },
        "upvotedBy": { "type": "array", "description": "UIDs of users who upvoted" },
        "resolvedImageUrl": { "type": "string", "description": "Optional resolution proof photo URL" },
        "resolvedBy": { "type": "string", "description": "Optional display name of the resolver" },
        "aiCautionTips": { "type": "string", "description": "Safety advice generated by Gemini" },
        "createdAt": { "type": "integer", "description": "Timestamp of report creation" },
        "updatedAt": { "type": "integer", "description": "Timestamp of last modification" },
        "comments": { "type": "array", "description": "List of comment objects" }
      },
      "required": ["id", "reporterId", "reporterName", "title", "description", "category", "severity", "imageUrl", "lat", "lng", "formattedAddress", "status", "upvoteCount", "upvotedBy", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User account and gamification profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Verified UID of the user" },
        "displayName": { "type": "string", "description": "User chosen name" },
        "email": { "type": "string", "description": "E-mail of the user" },
        "avatarUrl": { "type": "string", "description": "Avatar image link" },
        "points": { "type": "integer", "description": "Current points accumulated" },
        "badges": { "type": "array", "description": "List of unlocked badges" },
        "createdAt": { "type": "integer", "description": "Timestamp when profile was initialized" }
      },
      "required": ["uid", "displayName", "email", "avatarUrl", "points", "badges", "createdAt"]
    }
  },
  "firestore": {
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Active community reports and updates"
    },
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and scores"
    }
  }
}
